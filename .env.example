# Database Configuration
DATABASE_URL=sqlite:///./threads_automation.db
# For PostgreSQL: postgresql://user:password@localhost:5432/threads_automation

# Application Settings
APP_NAME=Threads Automation
APP_VERSION=1.0.0
DEBUG=False
SECRET_KEY=  # REQUIRED

# LLM Configuration
LLM_PROVIDER=ollama  # Options: ollama, openai, custom
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=  # Optional, for OpenAI-compatible APIs
LLM_MODEL=llama2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500
LLM_TIMEOUT=60

# Threads Publisher Configuration
THREADS_PUBLISHER=mock  # Options: mock, api, browser
THREADS_API_URL=https://api.threads.net/v1
THREADS_API_KEY=  # Your Threads API key (when available)

# Scheduler Configuration
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC
CONTENT_PLAN_DAYS_AHEAD=7  # Generate plans for next N days
GENERATION_HOURS_BEFORE=2  # Generate content N hours before posting

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300  # 5 minutes
RETRY_BACKOFF_MULTIPLIER=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS (for frontend integration)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=  # REQUIRED
