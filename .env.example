# ============================================================
# Threads Automation — example configuration
# Copy to .env and fill in required values
# ============================================================

# Application
SECRET_KEY=           # REQUIRED — random string, e.g.: openssl rand -hex 32
DEBUG=False

# Database
DATABASE_URL=sqlite:///./threads_automation.db
# PostgreSQL: postgresql+asyncpg://user:password@localhost:5432/threads_automation

# Admin UI
ADMIN_USERNAME=admin
ADMIN_PASSWORD=       # REQUIRED

# LLM
LLM_PROVIDER=ollama   # ollama | openai | custom
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=          # optional — for OpenAI-compatible APIs
LLM_MODEL=llama2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500
LLM_TIMEOUT=60

# Publisher
THREADS_PUBLISHER=browser   # mock | api | browser

# Threads API publisher (Meta Graph API v1.0)
THREADS_APP_ID=             # from developers.facebook.com
THREADS_APP_SECRET=         # from developers.facebook.com
THREADS_REDIRECT_URI=http://localhost:8000/api/accounts/oauth/callback

# Browser publisher (Playwright)
BROWSER_HEADLESS=False
BROWSER_LOGIN_TIMEOUT=60

# Vision agent (Qwen VL via Ollama)
VISION_MODEL=qwen2.5vl:7b
VISION_BASE_URL=http://localhost:11434
VISION_TIMEOUT=60

# Scheduler
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=UTC
CONTENT_PLAN_DAYS_AHEAD=7
GENERATION_HOURS_BEFORE=2

# Retry
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300
RETRY_BACKOFF_MULTIPLIER=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
